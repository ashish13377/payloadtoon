NODE_ENV=development
PORT=3000
GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_INITIAL_DELAY_MS=500
GEMINI_RETRY_MAX_DELAY_MS=8000
CORS_ORIGINS=http://localhost:3001
MAX_JSON_BODY_SIZE=10mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Ledger works without Docker/Redis. Leave REDIS_URL empty for in-memory analytics.
LEDGER_ENABLED=true
REDIS_URL=
LEDGER_KEY_PREFIX=payloadtoon:ledger
GEMINI_INPUT_PRICE_PER_1M_USD=0.30

# Used only by the example Next.js dashboard.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# Stored context/session settings
CONTEXT_STORE_ENABLED=true
CONTEXT_KEY_PREFIX=payloadtoon:context
CONTEXT_TTL_SECONDS=21600


